a:["$","main",null,{"children":[["$","section",null,{"className":"what-is reveal","id":"what","children":["$","div",null,{"className":"container","children":[["$","div",null,{"className":"section-eyebrow","children":"01 · About"}],["$","h2",null,{"children":["What is the ",["$","em",null,{"children":"South Indian Creators Economy?"}]]}],["$","div",null,{"className":"what-grid","children":[["$","div",null,{"children":[["$","p",null,{"className":"lede","children":"SICE is a regional media platform that exists to do three things well — publish South Indian creators, host them in person, and connect them to brand work that pays regional rates fairly."}],["$","p",null,{"style":{"fontSize":"15px","lineHeight":"1.7","color":"rgba(8,13,38,0.78)","maxWidth":"560px"},"children":["We are not a talent agency. We are not a community group. We are a working media business with revenue lines, accountable outputs, and a regional focus that runs deeper than most national networks ever attempt.",["$","br",null,{}],["$","br",null,{}],"Most creator platforms treat South India as one segment of a national strategy. SICE is built the other way around — this region first, full stop. We work with creators whose audiences live in Kerala, Tamil Nadu, Karnataka, Telangana, and Andhra Pradesh, and with the diaspora that watches from the Gulf, Singapore, and beyond.",["$","br",null,{}],["$","br",null,{}],"We don't claim to solve every problem a creator has. We focus on three: getting the work seen, putting the right creator in front of the right brand, and creating room for creators to meet each other in real life."]}]]}],["$","ul",null,{"className":"what-list","children":[["$","li","01",{"children":[["$","div",null,{"className":"what-list-num","children":"01"}],["$","div",null,{"className":"what-list-content","children":[["$","h3",null,{"children":"Not an agency"}],["$","p",null,{"children":"We don’t represent creators on commission. The relationship is platform-to-creator, not agent-to-client."}]]}]]}],["$","li","02",{"children":[["$","div",null,{"className":"what-list-num","children":"02"}],["$","div",null,{"className":"what-list-content","children":[["$","h3",null,{"children":"Not a community"}],["$","p",null,{"children":"Communities are unmonetized and voluntary. SICE is a working business with revenue lines and accountable outputs."}]]}]]}],["$","li","03",{"children":[["$","div",null,{"className":"what-list-num","children":"03"}],["$","div",null,{"className":"what-list-content","children":[["$","h3",null,{"children":"Not a luxury body"}],["$","p",null,{"children":"Luxury requires legacy. SICE is new. We aim to be premium and modern — not aristocratic."}]]}]]}],["$","li","04",{"children":[["$","div",null,{"className":"what-list-num","children":"04"}],["$","div",null,{"className":"what-list-content","children":[["$","h3",null,{"children":"Not pan-Indian"}],["$","p",null,{"children":"We are South Indian. The four languages, the regional context, and the cultural specificity are the point."}]]}]]}]]}]]}]]}]}],["$","section",null,{"className":"vision-mission reveal","id":"vision","children":["$","div",null,{"className":"container","children":[["$","div",null,{"className":"section-eyebrow","children":"02 · Direction"}],["$","h2",null,{"children":["Vision and Mission. ",["$","em",null,{"children":"Stated plainly."}]]}],["$","p",null,{"className":"lede","children":"A vision is what we want the region to look like in ten years. A mission is what we are doing this year to get there. Both kept short."}],["$","div",null,{"className":"vm-grid","children":[["$","article",null,{"className":"vm-card","children":[["$","div",null,{"children":[["$","div",null,{"className":"vm-eyebrow","children":"— Vision"}],["$","div",null,{"className":"vm-heading","children":"South Indian creators, working as recognized professionals — locally, fairly, and visibly."}],["$","p",null,{"className":"vm-body","children":"A region where a Malayalam creator in Calicut, a Tamil creator in Madurai, or a Telugu creator in Vijayawada earns from their craft as a registered profession — not a side hustle, not a grey-zone informal job, but a legitimate career with the same recognition, protections, and economic dignity as any other."}]]}],"$Lf"]}],"$L10"]}]]}]}],"$L11","$L12","$L13","$L14","$L15","$L16","$L17","$L18","$L19"]}]
