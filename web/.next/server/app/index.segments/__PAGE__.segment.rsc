12:["$","section",null,{"className":"gov-context reveal","id":"gov-context","children":["$","div",null,{"className":"container","children":[["$","div",null,{"className":"section-eyebrow","children":"03 · Context"}],["$","h2",null,{"children":["India recognized creators as professionals. ",["$","em",null,{"children":"SICE is built for that moment."}]]}],["$","p",null,{"className":"lede","children":"On 14 April 2026, the Rajya Sabha passed the National Creator Economy Bill — one of the first laws of its kind anywhere in the world. SICE is being built in alignment with the framework this bill creates."}],["$","div",null,{"className":"gov-grid","children":[["$","article",null,{"className":"gov-card","children":[["$","div",null,{"className":"gov-card-eyebrow","children":"National Creator Economy Bill 2026"}],["$","h3",null,{"children":"For the first time, Indian law treats creators as a profession — not a gig."}],["$","p",null,{"children":"The bill formally recognizes social media creators, YouTubers, streamers, digital artists, and podcasters as licensed professionals under Indian law. Previously, creators operated in a legal grey zone — classified as informal workers, with limited access to insurance, structured contracts, or formal financial recognition."}],["$","p",null,{"children":"Key provisions include mandatory registration with the Ministry of Information and Broadcasting for high-earning creators, standardized contract frameworks, AI content labelling requirements, and the establishment of a Creator Welfare Fund."}],["$","div",null,{"className":"citation","children":["Source: Reporting on the National Creator Economy Bill 2026, passed by Rajya Sabha 14 April 2026. The bill awaits Presidential Assent at the time of publication."," ",["$","a",null,{"href":"https://www.sansalegal.com/post/national-creator-economy-bill-2026-legal-framework-for-influencers-and-digital-creators-in-india","target":"_blank","rel":"noopener","children":"Read full legal analysis →"}]]}]]}],["$","aside",null,{"className":"gov-key-points","children":[["$","h3",null,{"children":"What the bill changes for creators."}],["$","ul",null,{"className":"gov-key-list","children":[["$","li","0",{"children":[["$","span",null,{"className":"gov-key-list-num","children":"01"}],["$","span",null,{"dangerouslySetInnerHTML":{"__html":"Creators are legally recognized as professionals — not informal workers"}}]]}],["$","li","1",{"children":[["$","span",null,{"className":"gov-key-list-num","children":"02"}],["$","span",null,{"dangerouslySetInnerHTML":{"__html":"Registration with the Ministry of I&B for creators above an income threshold"}}]]}],["$","li","2",{"children":[["$","span",null,{"className":"gov-key-list-num","children":"03"}],["$","span",null,{"dangerouslySetInnerHTML":{"__html":"Standardized contract templates and disclosure rules for brand partnerships"}}]]}],["$","li","3",{"children":[["$","span",null,{"className":"gov-key-list-num","children":"04"}],["$","span",null,{"dangerouslySetInnerHTML":{"__html":"Creator Welfare Fund — health insurance, accidental cover, retirement provisions"}}]]}],["$","li","4",{"children":[["$","span",null,{"className":"gov-key-list-num","children":"05"}],["$","span",null,{"dangerouslySetInnerHTML":{"__html":"Mandatory AI-content labelling for synthetic or deepfake-generated work"}}]]}],["$","li","5",{"children":[["$","span",null,{"className":"gov-key-list-num","children":"06"}],["$","span",null,{"dangerouslySetInnerHTML":{"__html":"Access to formal financial products — business loans, insurance, professional credit"}}]]}]]}]]}]]}],["$","div",null,{"className":"gov-sources-row","children":[["$","a","PM India · Official",{"href":"https://www.pmindia.gov.in/en/news_updates/pm-presents-first-ever-national-creators-award/","target":"_blank","rel":"noopener","className":"gov-source","children":[["$","div",null,{"className":"gov-source-label","children":"PM India · Official"}],["$","div",null,{"className":"gov-source-title","children":"National Creators Award presented by PM Modi at Bharat Mandapam"}],"$L1e"]}],"$L1f","$L20"]}],"$L21"]}]}]
13:["$","section",null,{"className":"pillars reveal","children":["$","div",null,{"className":"container","children":[["$","div",null,{"className":"section-eyebrow light","children":"04 · What we do"}],["$","h2",null,{"className":"light","children":["Three jobs. ",["$","em",null,{"children":"Done well."}]]}],["$","p",null,{"className":"lede light","children":"A media platform's value comes from doing a few things consistently — not many things occasionally. These are ours."}],["$","div",null,{"className":"pillars-grid","children":[["$","article","Pillar 01",{"className":"pillar","children":[["$","div",null,{"className":"pillar-num","children":"Pillar 01"}],["$","h3",null,{"children":"Publish"}],["$","p",null,{"children":"Long-form features, profiles, and editorial work spotlighting regional creators. Distributed through our channels and amplified to brand partners. Original writing, native-language coverage, no recycled press releases."}]]}],["$","article","Pillar 02",{"className":"pillar","children":[["$","div",null,{"className":"pillar-num","children":"Pillar 02"}],["$","h3",null,{"children":"Host"}],["$","p",null,{"children":"Monthly chapter meetups in Calicut, Kochi, Bangalore, Chennai, and Hyderabad. In-person, working sessions — not networking theatre. Skill workshops, peer review, and structured introductions to peers in the room."}]]}],["$","article","Pillar 03",{"className":"pillar","children":[["$","div",null,{"className":"pillar-num","children":"Pillar 03"}],["$","h3",null,{"children":"Connect"}],["$","p",null,{"children":"Brand partnerships matched to creator fit, not just follower count. We negotiate regional rates that reflect what the work is worth — not what Mumbai-based agencies decide South Indian audiences are worth."}]]}]]}]]}]}]
