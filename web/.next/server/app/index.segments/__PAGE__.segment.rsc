16:["$","section",null,{"className":"developer reveal","id":"developer","children":["$","div",null,{"className":"container","children":[["$","div",null,{"className":"section-eyebrow light","children":"07 · Behind the build"}],["$","h2",null,{"className":"light","children":["Developed by ",["$","em",null,{"children":"ElevateX Now."}]]}],["$","p",null,{"className":"lede light","children":"SICE is built and operated by ElevateX Now — an integrated business services firm based in Calicut, serving 500+ startups and growing businesses across India since 2019."}],["$","div",null,{"className":"developer-grid","children":[["$","aside",null,{"className":"developer-mark","children":[["$","div",null,{"className":"developer-mark-text","children":"ELEVATEX"}],["$","div",null,{"className":"developer-mark-tagline","children":"Powering Digital Success"}],["$","div",null,{"className":"developer-stats","children":[["$","div","Startups Served",{"children":[["$","div",null,{"className":"developer-stat-num","children":"500+"}],["$","div",null,{"className":"developer-stat-label","children":"Startups Served"}]]}],["$","div","Founded",{"children":[["$","div",null,{"className":"developer-stat-num","children":"2019"}],["$","div",null,{"className":"developer-stat-label","children":"Founded"}]]}],["$","div","Delivery Rate",{"children":[["$","div",null,{"className":"developer-stat-num","children":"98%"}],["$","div",null,{"className":"developer-stat-label","children":"Delivery Rate"}]]}]]}]]}],["$","div",null,{"className":"developer-content","children":[["$","p",null,{"style":{"fontSize":"16px","lineHeight":"1.7","color":"rgba(240,235,224,0.82)","marginBottom":"24px"},"children":"ElevateX Now was built to end the fragmentation that kills most early-stage businesses — five different vendors who never speak to each other, each pulling in a different direction."}],["$","p",null,{"style":{"fontSize":"15px","lineHeight":"1.7","color":"rgba(240,235,224,0.72)","marginBottom":"24px"},"children":"One integrated team handles legal incorporation, brand identity, performance marketing, and strategic consulting under a single brief. That same model is now being applied to building media platforms — SICE is the first."}],["$","div",null,{"className":"developer-pillars","children":[["$","div","Foundation",{"className":"developer-pillar","children":[["$","strong",null,{"children":"Foundation"}],"Company registration, GST, MSME, annual compliance."]}],["$","div","Shield",{"className":"developer-pillar","children":[["$","strong",null,{"children":"Shield"}],"Trademark, IP protection, founder agreements."]}],["$","div","Identity",{"className":"developer-pillar","children":[["$","strong",null,{"children":"Identity"}],"Branding, website, design, media assets."]}],["$","div","Engine",{"className":"developer-pillar","children":[["$","strong",null,{"children":"Engine"}],"Performance marketing, SEO, paid campaigns."]}]]}],["$","a",null,{"href":"https://elevatexnow.com","target":"_blank","rel":"noopener","className":"btn-primary","style":{"background":"var(--gold)"},"children":"Visit ElevateX Now →"}]]}]]}]]}]}]
17:["$","section",null,{"className":"editorial reveal","id":"editorial","children":["$","div",null,{"className":"container","children":[["$","div",null,{"className":"section-eyebrow","children":"08 · Editorial"}],["$","h2",null,{"children":["What we publish. ",["$","em",null,{"children":"Read first."}]]}],["$","p",null,{"className":"lede","children":"Editorial isn't a side project — it's the main one. Every feature is original writing, regionally specific, and built to be read end-to-end."}],["$","article",null,{"className":"editorial-feature","children":[["$","div",null,{"className":"article-tag","children":"Featured · Kerala"}],["$","h3",null,{"children":"How a Calicut-based satirist built a 600,000-strong Malayalam audience without leaving Kerala."}],["$","p",null,{"className":"article-lede","children":"A profile of one of the region's most quietly successful Malayalam-language creators — and what regional creators everywhere can learn from her playbook."}],["$","div",null,{"className":"article-meta","children":"By the SICE Editorial Desk · 7 minute read · May 2026"}]]}],["$","div",null,{"className":"editorial-list","children":[["$","article","Industry · PolicyWhat the National Creator Economy Bill 2026 changes for a working creator.",{"className":"editorial-card","children":[["$","div",null,{"className":"article-tag","children":"Industry · Policy"}],["$","h3",null,{"children":"What the National Creator Economy Bill 2026 changes for a working creator."}],["$","p",null,{"children":"A plain-English breakdown of what creators must do to register, what protections kick in, and what brands must now disclose."}],["$","div",null,{"className":"article-meta","children":"10 minute read · May 2026"}]]}],["$","article","Tamil NaduThe economics of being a Tamil food creator in 2026.",{"className":"editorial-card","children":[["$","div",null,{"className":"article-tag","children":"Tamil Nadu"}],["$","h3",null,{"children":"The economics of being a Tamil food creator in 2026."}],["$","p",null,{"children":"What regional food creators earn, what brands actually pay, and why most reported numbers are wrong."}],["$","div",null,{"className":"article-meta","children":"5 minute read · May 2026"}]]}],["$","article","DiasporaInside the Malayalam creator economy of the Gulf.",{"className":"editorial-card","children":[["$","div",null,{"className":"article-tag","children":"Diaspora"}],["$","h3",null,{"children":"Inside the Malayalam creator economy of the Gulf."}],["$","p",null,{"children":"How GCC-based Malayalam creators are outperforming domestic peers — and what local brands are missing."}],["$","div",null,{"className":"article-meta","children":"6 minute read · April 2026"}]]}],["$","article","KarnatakaKannada gaming is having its moment. The brands aren't ready.",{"className":"editorial-card","children":[["$","div",null,{"className":"article-tag","children":"Karnataka"}],["$","h3",null,{"children":"Kannada gaming is having its moment. The brands aren't ready."}],["$","p",null,{"children":"A market analysis of Kannada gaming creators and the slow pace of regional brand spend."}],["$","div",null,{"className":"article-meta","children":"8 minute read · April 2026"}]]}]]}]]}]}]
18:["$","section",null,{"className":"faq reveal","children":["$","div",null,{"className":"container","children":[["$","div",null,{"className":"section-eyebrow","children":"09 · Questions"}],["$","h2",null,{"children":["Common questions. ",["$","em",null,{"children":"Direct answers."}]]}],["$","div",null,{"className":"faq-list","children":[["$","details","What is SICE, in one sentence?",{"className":"faq-item","children":[["$","summary",null,{"children":"What is SICE, in one sentence?"}],["$","p",null,{"children":"SICE is a media platform for South Indian creators — publishing work in Malayalam, Tamil, Telugu, and Kannada, hosting in-person chapters across the region, and connecting creators to brand work that pays fairly."}]]}],["$","details","Who developed SICE?",{"className":"faq-item","children":[["$","summary",null,{"children":"Who developed SICE?"}],["$","p",null,{"children":"SICE is developed and operated by ElevateX Now — an integrated business services firm based in Calicut, Kerala, founded in 2019. ElevateX Now has supported over 500 startups and MSMEs across India in legal, branding, and marketing functions, and is now applying that integrated model to building media platforms."}]]}],["$","details","Is SICE aligned with the National Creator Economy Bill 2026?",{"className":"faq-item","children":[["$","summary",null,{"children":"Is SICE aligned with the National Creator Economy Bill 2026?"}],["$","p",null,{"children":"Yes. The National Creator Economy Bill 2026, passed by the Rajya Sabha on 14 April 2026, formally recognizes creators as licensed professionals under Indian law. SICE is being built in alignment with the framework this bill establishes — including the registration requirements, contract standards, and disclosure rules it introduces. The bill awaits Presidential Assent at the time of publication."}]]}],["$","details","Who can apply?",{"className":"faq-item","children":[["$","summary",null,{"children":"Who can apply?"}],["$","p",null,{"children":"Working creators based in South India, or creators producing content in a South Indian language from anywhere in the world. There is no minimum follower count. We look for consistent original work and a clear voice. Application is open year-round."}]]}],["$","details","Is SICE a talent agency?",{"className":"faq-item","children":[["$","summary",null,{"children":"Is SICE a talent agency?"}],["$","p",null,{"children":"No. We don't represent creators for commissions. We publish their work, host events, and facilitate brand connections — but the relationship is platform-to-creator, not agent-to-client. Creators retain full control of their work."}]]}],["$","details","How does the brand-partnership marketplace work?",{"className":"faq-item","children":[["$","summary",null,{"children":"How does the brand-partnership marketplace work?"}],["$","p",null,{"children":"Brands brief us on what they're looking for. We match the brief to members based on audience fit, voice, and creative direction — not just follower count. Members opt in to each pitch individually. We don't take a commission on the deal."}]]}],["$","details","Where is SICE based?",{"className":"faq-item","children":[["$","summary",null,{"children":"Where is SICE based?"}],["$","p",null,{"children":"SICE is headquartered in Calicut, Kerala — operating from HiLite Business Park, the same office as ElevateX Now. Active and planned chapters span Kerala, Tamil Nadu, Karnataka, Telangana, and Andhra Pradesh, with a digital chapter for the GCC diaspora under exploration."}]]}]]}]]}]}]
