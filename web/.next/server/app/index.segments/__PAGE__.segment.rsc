10:["$","article",null,{"className":"vm-card light","children":[["$","div",null,{"children":[["$","div",null,{"className":"vm-eyebrow","children":"— Mission"}],["$","div",null,{"className":"vm-heading","children":"Build the platform that makes that vision real for working creators today."}],["$","p",null,{"className":"vm-body","children":"Publish original editorial work that puts regional creators in front of brands and audiences who otherwise wouldn't see them. Host chapter meetups that turn isolated creators into a working network. Connect creators to brand partnerships negotiated at fair regional rates — not at rates set by Mumbai-based agencies who decide what regional audiences are worth."}]]}],["$","div",null,{"className":"vm-stamp","children":"In motion this year"}]]}]
